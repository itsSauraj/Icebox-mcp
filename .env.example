# Copy to .env for local use, and set the same vars in your Vercel project's
# Environment Variables for production.

# OpenAI Apps domain-verification challenge token.
# OpenAI gives you this value; it is served verbatim at
#   /.well-known/openai-apps-challenge
# so OpenAI can confirm you control the domain.
OPEN_AI_APP_CHALLANGE=

# Optional: the exact sandbox origin a host expects for app submission.
# Leave unset for normal use (each host uses its own default origin).
APP_DOMAIN=
